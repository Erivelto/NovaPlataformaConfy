      "path": "/api/SistemaUsuario/{id}",
      "description": "Obter sistema usuário por ID"
    },
    {
      "method": "PUT",
      "path": "/api/SistemaUsuario/{id}",
      "description": "Atualizar sistema usuário"
    },
    {
      "method": "DELETE",
      "path": "/api/SistemaUsuario/{id}",
      "description": "Deletar sistema usuário"
    },
    {
      "method": "GET",
      "path": "/api/SistemaUsuario/apelido/{apelido}",
      "description": "Buscar por apelido"
    },
    {
      "method": "GET",
      "path": "/api/SistemaUsuario/status/{status}",
      "description": "Listar por status"
    }
