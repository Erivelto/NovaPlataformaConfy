{
  "name": "SistemaUsuario",
  "baseUrl": "/api/SistemaUsuario",
  "endpoints": [
    {
      "method": "GET",
      "path": "/api/SistemaUsuario",
      "description": "Listar todos os sistema usuários"
    },
    {
      "method": "POST",
      "path": "/api/SistemaUsuario",
      "description": "Criar novo sistema usuário"
    },
    {
